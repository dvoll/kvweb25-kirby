{
    "name": "dvll/kirby-wiki",
    "description": "Wiki access and protected download plugin for the KvWeb project",
    "license": "MIT",
    "type": "kirby-plugin",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Dario Voll",
            "email": "dariovoll@gmail.com"
        }
    ],
    "require": {
        "getkirby/composer-installer": "^1.2",
        "dvll/sitepackage": "@dev"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "getkirby/composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "dvll\\KirbyWiki\\": "src/"
        }
    }
}